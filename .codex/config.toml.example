# Example Codex configuration for the agent-harness-generator.
#
# Drop this at ~/.codex/config.toml (user-global) or .codex/config.toml
# (project, requires "trusted project" status per OpenAI codex#3441).
#
# Verified surface: https://developers.openai.com/codex/mcp

[mcp_servers.agent-harness-generator]
command = "npx"
args = ["-y", "create-agent-harness@latest", "mcp-serve"]

# Optional environment for the MCP server. Use Streamable HTTP form
# instead if your harness is hosted (see codex docs for bearer_token_env_var).

[mcp_servers.agent-harness-generator.env]
RUFLO_KERNEL_LOG_LEVEL = "info"
